{
  "name": "vaso-web",
  "private": true,
  "version": "1.0.9",
  "description": "Générateur paramétrique de vases pour impression 3D",
  "author": {
    "name": "mrklm",
    "email": "mrklm@users.noreply.github.com"
  },
  "homepage": "https://github.com/mrklm/vaso",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "npm run lint:oxlint && npm run lint:style",
    "lint:oxlint": "oxlint --config oxlint.json src/",
    "lint:style": "stylelint 'src/**/*.css'",
    "format": "oxfmt --write 'src/**/*.{ts,tsx}'",
    "format:check": "oxfmt --check 'src/**/*.{ts,tsx}'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "check": "npm run lint && npm run format:check && npm run build && npm run test",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "ELECTRON=1 npm run build && electron-builder",
    "electron:build:linux": "ELECTRON=1 npm run build && electron-builder --linux",
    "electron:build:mac": "ELECTRON=1 npm run build && electron-builder --mac",
    "electron:build:win": "ELECTRON=1 npm run build && electron-builder --win"
  },
  "build": {
    "appId": "com.mrklm.vaso",
    "productName": "Vaso",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "public/favicon.svg",
      "category": "Graphics"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "public/favicon.svg",
      "category": "public.app-category.graphics-design"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/favicon.svg"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/postprocessing": "^3.0.4",
    "postprocessing": "^6.39.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hot-toast": "^2.6.0",
    "seedrandom": "^3.0.5",
    "three": "^0.183.2",
    "three-bvh-csg": "^0.0.18",
    "three-mesh-bvh": "^0.9.9",
    "zundo": "^2.3.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/seedrandom": "^3.0.8",
    "@types/three": "^0.183.1",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "stylelint": "^17.5.0",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vitest": "^4.1.0",
    "wait-on": "^9.0.4"
  }
}
